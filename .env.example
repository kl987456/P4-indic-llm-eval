# ── LLM Provider API Keys ──────────────────────────────────────────────────────
# Anthropic Claude (required when using AnthropicAdapter)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (required when using OpenAIAdapter)
OPENAI_API_KEY=sk-...

# Hugging Face token (required to download gated models e.g. Llama, Gemma)
HF_TOKEN=hf_...

# ── Ollama (self-hosted / local models) ────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Evaluation settings ────────────────────────────────────────────────────────
# Default model adapter when not specified in a task config
DEFAULT_MODEL=claude-sonnet-4-6

# Parallel eval workers (set to 1 to disable parallelism)
EVAL_WORKERS=4

# Directory where benchmark reports and per-task JSON results are written
EVAL_OUTPUT_DIR=./eval_results

# ── Database (stores run history and results) ──────────────────────────────────
DATABASE_URL=sqlite:///./eval.db

# ── Security (REST API) ────────────────────────────────────────────────────────
API_KEY=
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8003
